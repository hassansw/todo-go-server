# ============================================================
# TODO Server — Environment Configuration
# ============================================================

# ----- Server -----
PORT=8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=15s

# ----- Database -----
# Used for local go run / go test. Docker Compose overrides DATABASE_URL at runtime.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tododb
DATABASE_URL=postgresql://neondb_owner:npg_ByWwx1PHqKt5@ep-super-unit-a1sunqp8-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=requireDB_MAX_OPEN=25
DB_MAX_IDLE=10
DB_MAX_LIFE=5m

# ----- JWT (REQUIRED — change before deploying!) -----
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h   # 7 days

# ----- Uploads -----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# ----- Rate Limiting -----
RATE_LIMIT=10       # requests per second per IP
RATE_BURST=20

# ----- CORS -----
ALLOWED_ORIGIN=http://localhost:3000

# ----- Security -----
BCRYPT_COST=12
